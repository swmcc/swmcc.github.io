---
import BaseLayout from '../layouts/BaseLayout.astro';
import GitHubActivity from '../components/GitHubActivity.astro';
import OSSProjects from '../components/OSSProjects.astro';

const url = Astro.url;
const view = url.searchParams.get('view') || 'activity';
const isOSS = view === 'oss';
---

<BaseLayout
  title="Codin' - Stephen McCullough"
  description={isOSS ? "Open source packages and contributions" : "Recent coding activity and GitHub commits"}
>
  <div class="max-w-6xl mx-auto">
    <!-- Tab Navigation - Ribbon Style -->
    <nav class="flex gap-2 mt-24 px-4 mb-6">
      <a
        href="/codin"
        class:list={[
          "px-4 py-2 text-xs font-black uppercase tracking-wider shadow-lg transition-all",
          !isOSS
            ? "bg-[var(--color-accent)] text-white"
            : "bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-secondary)]"
        ]}
      >
        Recent Activity
      </a>
      <a
        href="/codin?view=oss"
        class:list={[
          "px-4 py-2 text-xs font-black uppercase tracking-wider shadow-lg transition-all",
          isOSS
            ? "bg-[var(--color-accent)] text-white"
            : "bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-secondary)]"
        ]}
      >
        Open Source
      </a>
    </nav>

    <!-- Content -->
    {isOSS ? <OSSProjects showRibbon={false} /> : <GitHubActivity showRibbon={false} />}
  </div>
</BaseLayout>
