---
import { ossProjects, sectionIntro } from '../data/oss-projects';

interface Props {
  showRibbon?: boolean;
  hideWrapper?: boolean;
}

const { showRibbon = true, hideWrapper = false } = Astro.props;
const myPackages = ossProjects.filter(p => p.type === 'package');
const contributions = ossProjects.filter(p => p.type === 'contribution');
---

{hideWrapper ? (
  <Fragment>
    <div class="flex items-center gap-3 mb-6">
      <div class="w-16 h-16 rounded-full bg-gradient-to-br from-green-400/30 to-emerald-400/30 flex items-center justify-center">
        <svg class="w-8 h-8" style="color: var(--color-accent);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
        </svg>
      </div>
      <div>
        <h2 style="color: var(--color-text-heading);" class="text-2xl font-bold">Open Source</h2>
        <p style="color: var(--color-text-secondary);" class="text-sm">Packages I maintain & projects I contribute to</p>
      </div>
    </div>

    <p style="color: var(--color-text-secondary);" class="text-base mb-8 leading-relaxed">
      {sectionIntro}
    </p>

    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-400/30 to-indigo-400/30 flex items-center justify-center">
          <svg class="w-5 h-5" style="color: var(--color-accent);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        </div>
        <h3 style="color: var(--color-text-heading);" class="text-sm font-semibold uppercase tracking-wider">My Packages</h3>
      </div>
      <div id="my-packages-content" class="space-y-4">
        {myPackages.map(project => (
          <div
            class="oss-project-card"
            data-repo={project.repo}
            data-pypi={project.links.pypi || ''}
            data-rubygems={project.links.rubygems || ''}
            data-my-description={project.myDescription || ''}
            style="background: var(--color-bg-secondary); border: 1px solid var(--color-border);"
          >
            <div class="p-4 rounded-lg">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h4 style="color: var(--color-accent);" class="font-semibold text-lg">{project.name}</h4>
                <span class="pkg-version text-xs px-2 py-0.5 rounded" style="background: var(--color-accent); color: white; display: none;"></span>
              </div>
              <p class="github-description text-base italic mb-3" style="color: var(--color-text-muted);">Loading...</p>

              <!-- Stats row -->
              <div class="flex flex-wrap gap-4 mb-3 text-sm" style="color: var(--color-text-muted);">
                <span class="github-stars flex items-center gap-1" style="display: none;">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/></svg>
                  <span class="stars-count">0</span>
                </span>
                <span class="github-watchers flex items-center gap-1" style="display: none;">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  <span class="watchers-count">0</span>
                </span>
                <span class="github-commits flex items-center gap-1" style="display: none;">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <span class="commits-info">-</span>
                </span>
              </div>

              <!-- Links row -->
              <div class="flex flex-wrap gap-3 mb-3">
                <a href={project.links.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-xs px-2 py-1 rounded transition-opacity hover:opacity-70" style="background: var(--color-bg-tertiary); color: var(--color-text);">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                  View on GitHub
                </a>
                {project.links.pypi && (
                  <a href={project.links.pypi} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-xs px-2 py-1 rounded transition-opacity hover:opacity-70" style="background: var(--color-bg-tertiary); color: var(--color-text);">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.2-.01.13V8.5l-.05.63-.13.55-.21.46-.26.38-.3.31-.33.25-.35.19-.35.14-.33.1-.3.07-.26.04-.21.02H8.77l-.69.05-.59.14-.5.22-.41.27-.33.32-.27.35-.2.36-.15.37-.1.35-.07.32-.04.27-.02.21v3.06H3.17l-.21-.03-.28-.07-.32-.12-.35-.18-.36-.26-.36-.36-.35-.46-.32-.59-.28-.73-.21-.88-.14-1.05-.05-1.23.06-1.22.16-1.04.24-.87.32-.71.36-.57.4-.44.42-.33.42-.24.4-.16.36-.1.32-.05.24-.01h.16l.06.01h8.16v-.83H6.18l-.01-2.75-.02-.37.05-.34.11-.31.17-.28.25-.26.31-.23.38-.2.44-.18.51-.15.58-.12.64-.1.71-.06.77-.04.84-.02 1.27.05zm-6.3 1.98l-.23.33-.08.41.08.41.23.34.33.22.41.09.41-.09.33-.22.23-.34.08-.41-.08-.41-.23-.33-.33-.22-.41-.09-.41.09zm13.09 3.95l.28.06.32.12.35.18.36.27.36.35.35.47.32.59.28.73.21.88.14 1.04.05 1.23-.06 1.23-.16 1.04-.24.86-.32.71-.36.57-.4.45-.42.33-.42.24-.4.16-.36.09-.32.05-.24.02-.16-.01h-8.22v.82h5.84l.01 2.76.02.36-.05.34-.11.31-.17.29-.25.25-.31.24-.38.2-.44.17-.51.15-.58.13-.64.09-.71.07-.77.04-.84.01-1.27-.04-1.07-.14-.9-.2-.73-.25-.59-.3-.45-.33-.34-.34-.25-.34-.16-.33-.1-.3-.04-.25-.02-.2.01-.13v-5.34l.05-.64.13-.54.21-.46.26-.38.3-.32.33-.24.35-.2.35-.14.33-.1.3-.06.26-.04.21-.02.13-.01h5.84l.69-.05.59-.14.5-.21.41-.28.33-.32.27-.35.2-.36.15-.36.1-.35.07-.32.04-.28.02-.21V6.07h2.09l.14.01zm-6.47 14.25l-.23.33-.08.41.08.41.23.33.33.23.41.08.41-.08.33-.23.23-.33.08-.41-.08-.41-.23-.33-.33-.23-.41-.08-.41.08z"/></svg>
                    PyPI
                  </a>
                )}
                {project.links.rubygems && (
                  <a href={project.links.rubygems} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-xs px-2 py-1 rounded transition-opacity hover:opacity-70" style="background: var(--color-bg-tertiary); color: var(--color-text);">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.25l8.25 4.714v9.536L12 21.214 3.75 16.5V6.964L12 2.25z"/></svg>
                    RubyGems
                  </a>
                )}
              </div>

              {project.myDescription && (<p class="text-base leading-relaxed" style="color: var(--color-text);">{project.myDescription}</p>)}
            </div>
          </div>
        ))}
      </div>
    </div>

    {contributions.length > 0 && (
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-400/30 to-amber-400/30 flex items-center justify-center">
            <svg class="w-5 h-5" style="color: var(--color-accent);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
          </div>
          <h3 style="color: var(--color-text-heading);" class="text-sm font-semibold uppercase tracking-wider">Contributions</h3>
        </div>
        <div id="contributions-content" class="space-y-4">
          {contributions.map(project => (
            <div
              class="oss-project-card"
              data-repo={project.repo}
              data-pypi={project.links.pypi || ''}
              data-rubygems={project.links.rubygems || ''}
              data-my-description={project.myDescription || ''}
              style="background: var(--color-bg-secondary); border: 1px solid var(--color-border);"
            >
              <div class="p-4 rounded-lg">
                <div class="flex items-start justify-between gap-4 mb-3">
                  <h4 style="color: var(--color-accent);" class="font-semibold text-lg">{project.name}</h4>
                  <span class="pkg-version text-xs px-2 py-0.5 rounded" style="background: var(--color-accent); color: white; display: none;"></span>
                </div>
                <p class="github-description text-base italic mb-3" style="color: var(--color-text-muted);">Loading...</p>

                <div class="flex flex-wrap gap-4 mb-3 text-sm" style="color: var(--color-text-muted);">
                  <span class="github-stars flex items-center gap-1" style="display: none;">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/></svg>
                    <span class="stars-count">0</span>
                  </span>
                  <span class="github-watchers flex items-center gap-1" style="display: none;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    <span class="watchers-count">0</span>
                  </span>
                  <span class="github-commits flex items-center gap-1" style="display: none;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="commits-info">-</span>
                  </span>
                </div>

                <div class="flex flex-wrap gap-3 mb-3">
                  <a href={project.links.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-xs px-2 py-1 rounded transition-opacity hover:opacity-70" style="background: var(--color-bg-tertiary); color: var(--color-text);">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    View on GitHub
                  </a>
                  {project.links.pypi && (
                    <a href={project.links.pypi} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-xs px-2 py-1 rounded transition-opacity hover:opacity-70" style="background: var(--color-bg-tertiary); color: var(--color-text);">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.2-.01.13V8.5l-.05.63-.13.55-.21.46-.26.38-.3.31-.33.25-.35.19-.35.14-.33.1-.3.07-.26.04-.21.02H8.77l-.69.05-.59.14-.5.22-.41.27-.33.32-.27.35-.2.36-.15.37-.1.35-.07.32-.04.27-.02.21v3.06H3.17l-.21-.03-.28-.07-.32-.12-.35-.18-.36-.26-.36-.36-.35-.46-.32-.59-.28-.73-.21-.88-.14-1.05-.05-1.23.06-1.22.16-1.04.24-.87.32-.71.36-.57.4-.44.42-.33.42-.24.4-.16.36-.1.32-.05.24-.01h.16l.06.01h8.16v-.83H6.18l-.01-2.75-.02-.37.05-.34.11-.31.17-.28.25-.26.31-.23.38-.2.44-.18.51-.15.58-.12.64-.1.71-.06.77-.04.84-.02 1.27.05zm-6.3 1.98l-.23.33-.08.41.08.41.23.34.33.22.41.09.41-.09.33-.22.23-.34.08-.41-.08-.41-.23-.33-.33-.22-.41-.09-.41.09zm13.09 3.95l.28.06.32.12.35.18.36.27.36.35.35.47.32.59.28.73.21.88.14 1.04.05 1.23-.06 1.23-.16 1.04-.24.86-.32.71-.36.57-.4.45-.42.33-.42.24-.4.16-.36.09-.32.05-.24.02-.16-.01h-8.22v.82h5.84l.01 2.76.02.36-.05.34-.11.31-.17.29-.25.25-.31.24-.38.2-.44.17-.51.15-.58.13-.64.09-.71.07-.77.04-.84.01-1.27-.04-1.07-.14-.9-.2-.73-.25-.59-.3-.45-.33-.34-.34-.25-.34-.16-.33-.1-.3-.04-.25-.02-.2.01-.13v-5.34l.05-.64.13-.54.21-.46.26-.38.3-.32.33-.24.35-.2.35-.14.33-.1.3-.06.26-.04.21-.02.13-.01h5.84l.69-.05.59-.14.5-.21.41-.28.33-.32.27-.35.2-.36.15-.36.1-.35.07-.32.04-.28.02-.21V6.07h2.09l.14.01zm-6.47 14.25l-.23.33-.08.41.08.41.23.33.33.23.41.08.41-.08.33-.23.23-.33.08-.41-.08-.41-.23-.33-.33-.23-.41-.08-.41.08z"/></svg>
                      PyPI
                    </a>
                  )}
                </div>

                {project.myDescription && (<p class="text-base leading-relaxed" style="color: var(--color-text);">{project.myDescription}</p>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </Fragment>
) : (
  <section class="max-w-6xl mx-auto">
    <div class="card animate-slide-in-left" style="animation-delay: 450ms;">
      {showRibbon && (
        <div class="absolute top-0 left-0 ribbon-top-left">
          <span style="background: var(--color-accent); color: white;" class="px-4 py-2 text-xs font-black uppercase tracking-wider shadow-lg">
            Open Source
          </span>
        </div>
      )}

      <div class:list={[showRibbon ? "mt-8" : "mt-2"]}>
      <div class="flex items-center gap-3 mb-6">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-green-400/30 to-emerald-400/30 flex items-center justify-center">
          <svg class="w-8 h-8" style="color: var(--color-accent);" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <div>
          <h2 style="color: var(--color-text-heading);" class="text-2xl font-bold">Open Source</h2>
          <p style="color: var(--color-text-secondary);" class="text-sm">Packages I maintain & projects I contribute to</p>
        </div>
      </div>

      <!-- Intro -->
      <p style="color: var(--color-text-secondary);" class="text-base mb-8 leading-relaxed">
        {sectionIntro}
      </p>

      <!-- My Packages -->
      <div class="mb-8">
        <h3 style="color: var(--color-text-heading);" class="text-sm font-semibold uppercase tracking-wider mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 inline-block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg> My Packages
        </h3>
        <div id="my-packages-content" class="space-y-4">
          {myPackages.map(project => (
            <div
              class="oss-project-card"
              data-repo={project.repo}
              data-my-description={project.myDescription || ''}
              style="background: var(--color-bg-secondary); border: 1px solid var(--color-border);"
            >
              <div class="p-4 rounded-lg">
                <div class="flex items-start justify-between gap-4 mb-2">
                  <h4 style="color: var(--color-accent);" class="font-semibold">{project.name}</h4>
                  <div class="flex gap-2 flex-shrink-0">
                    <a
                      href={project.links.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      style="color: var(--color-text-muted);"
                      class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
                    >
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                      </svg>
                      GitHub
                    </a>
                    {project.links.pypi && (
                      <a
                        href={project.links.pypi}
                        target="_blank"
                        rel="noopener noreferrer"
                        style="color: var(--color-text-muted);"
                        class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
                      >
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12.042 23.648c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637zm7.74-4.771c-.805-.503-1.227-1.064-1.227-1.637 0-.573.422-1.134 1.227-1.637.806.503 1.228 1.064 1.228 1.637 0 .573-.422 1.134-1.228 1.637zm-15.48 0c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637zm7.74-4.771c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637z"/>
                        </svg>
                        PyPI
                      </a>
                    )}
                    {project.links.rubygems && (
                      <a
                        href={project.links.rubygems}
                        target="_blank"
                        rel="noopener noreferrer"
                        style="color: var(--color-text-muted);"
                        class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
                      >
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.25l8.25 4.714v9.536L12 21.214 3.75 16.5V6.964L12 2.25z"/>
                        </svg>
                        RubyGems
                      </a>
                    )}
                  </div>
                </div>
                <p class="github-description text-sm italic mb-2" style="color: var(--color-text-muted);">
                  Loading...
                </p>
                {project.myDescription && (
                  <p class="text-sm leading-relaxed" style="color: var(--color-text);">
                    {project.myDescription}
                  </p>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Contributions -->
      {contributions.length > 0 && (
        <div>
          <h3 style="color: var(--color-text-heading);" class="text-sm font-semibold uppercase tracking-wider mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 inline-block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg> Contributions
          </h3>
          <div id="contributions-content" class="space-y-4">
            {contributions.map(project => (
              <div
                class="oss-project-card"
                data-repo={project.repo}
                data-my-description={project.myDescription || ''}
                style="background: var(--color-bg-secondary); border: 1px solid var(--color-border);"
              >
                <div class="p-4 rounded-lg">
                  <div class="flex items-start justify-between gap-4 mb-2">
                    <h4 style="color: var(--color-accent);" class="font-semibold">{project.name}</h4>
                    <div class="flex gap-2 flex-shrink-0">
                      <a
                        href={project.links.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        style="color: var(--color-text-muted);"
                        class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
                      >
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                        </svg>
                        GitHub
                      </a>
                      {project.links.pypi && (
                        <a
                          href={project.links.pypi}
                          target="_blank"
                          rel="noopener noreferrer"
                          style="color: var(--color-text-muted);"
                          class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
                        >
                          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12.042 23.648c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637zm7.74-4.771c-.805-.503-1.227-1.064-1.227-1.637 0-.573.422-1.134 1.227-1.637.806.503 1.228 1.064 1.228 1.637 0 .573-.422 1.134-1.228 1.637zm-15.48 0c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637zm7.74-4.771c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637z"/>
                          </svg>
                          PyPI
                        </a>
                      )}
                    </div>
                  </div>
                  <p class="github-description text-sm italic mb-2" style="color: var(--color-text-muted);">
                    Loading...
                  </p>
                  {project.myDescription && (
                    <p class="text-sm leading-relaxed" style="color: var(--color-text);">
                      {project.myDescription}
                    </p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>
)}

<script>
  const CACHE_KEY = 'oss-projects-cache';
  const CACHE_DURATION_MS = 60 * 60 * 1000; // 1 hour

  interface RepoData {
    description: string;
    stars: number;
    watchers: number;
    pushedAt: string;
    version?: string;
  }

  interface CacheData {
    [repo: string]: RepoData;
  }

  function getCachedData(): CacheData | null {
    try {
      const cached = localStorage.getItem(CACHE_KEY);
      if (!cached) return null;
      const { data, timestamp } = JSON.parse(cached);
      if (Date.now() - timestamp > CACHE_DURATION_MS) {
        localStorage.removeItem(CACHE_KEY);
        return null;
      }
      return data;
    } catch {
      return null;
    }
  }

  function setCachedData(data: CacheData): void {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify({ data, timestamp: Date.now() }));
    } catch {}
  }

  function formatCommitDate(dateStr: string): string {
    const date = new Date(dateStr);
    const now = new Date();
    const diffDays = Math.floor((now.getTime() - date.getTime()) / (1000 * 60 * 60 * 24));
    if (diffDays === 0) return 'today';
    if (diffDays === 1) return 'yesterday';
    if (diffDays < 7) return `${diffDays}d ago`;
    if (diffDays < 30) return `${Math.floor(diffDays / 7)}w ago`;
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  async function fetchPyPIVersion(pkgUrl: string): Promise<string | null> {
    try {
      const pkgName = pkgUrl.split('/project/')[1]?.replace(/\/$/, '');
      if (!pkgName) return null;
      const res = await fetch(`https://pypi.org/pypi/${pkgName}/json`);
      if (res.ok) {
        const data = await res.json();
        return data.info?.version || null;
      }
    } catch {}
    return null;
  }

  async function fetchRubyGemsVersion(gemUrl: string): Promise<string | null> {
    try {
      const gemName = gemUrl.split('/gems/')[1]?.replace(/\/$/, '');
      if (!gemName) return null;
      const res = await fetch(`https://rubygems.org/api/v1/gems/${gemName}.json`);
      if (res.ok) {
        const data = await res.json();
        return data.version || null;
      }
    } catch {}
    return null;
  }

  async function loadProjectData(): Promise<void> {
    const cards = document.querySelectorAll('.oss-project-card');
    const cachedData = getCachedData() || {};
    const reposToFetch: Array<{repo: string, pypi?: string, rubygems?: string}> = [];

    cards.forEach(card => {
      const repo = card.getAttribute('data-repo');
      if (repo && !cachedData[repo]) {
        reposToFetch.push({
          repo,
          pypi: card.getAttribute('data-pypi') || undefined,
          rubygems: card.getAttribute('data-rubygems') || undefined
        });
      }
    });

    if (reposToFetch.length > 0) {
      await Promise.all(reposToFetch.map(async ({ repo, pypi, rubygems }) => {
        try {
          const res = await fetch(`https://api.github.com/repos/${repo}`, {
            headers: { 'Accept': 'application/vnd.github+json' }
          });
          if (res.ok) {
            const data = await res.json();
            let version: string | undefined;
            if (pypi) version = await fetchPyPIVersion(pypi) || undefined;
            else if (rubygems) version = await fetchRubyGemsVersion(rubygems) || undefined;

            cachedData[repo] = {
              description: data.description || 'No description available',
              stars: data.stargazers_count || 0,
              watchers: data.subscribers_count || 0,
              pushedAt: data.pushed_at || '',
              version
            };
          }
        } catch (err) {
          console.error(`Failed to fetch ${repo}:`, err);
          cachedData[repo] = { description: 'No description available', stars: 0, watchers: 0, pushedAt: '' };
        }
      }));
      setCachedData(cachedData);
    }

    // Update DOM
    cards.forEach(card => {
      const repo = card.getAttribute('data-repo');
      if (!repo || !cachedData[repo]) return;
      const data = cachedData[repo];

      const descEl = card.querySelector('.github-description');
      if (descEl) descEl.textContent = `"${data.description}"`;

      const starsEl = card.querySelector('.github-stars');
      const starsCount = card.querySelector('.stars-count');
      if (starsEl && starsCount && data.stars > 0) {
        starsCount.textContent = String(data.stars);
        (starsEl as HTMLElement).style.display = 'flex';
      }

      const watchersEl = card.querySelector('.github-watchers');
      const watchersCount = card.querySelector('.watchers-count');
      if (watchersEl && watchersCount && data.watchers > 0) {
        watchersCount.textContent = String(data.watchers);
        (watchersEl as HTMLElement).style.display = 'flex';
      }

      const commitsEl = card.querySelector('.github-commits');
      const commitsInfo = card.querySelector('.commits-info');
      if (commitsEl && commitsInfo && data.pushedAt) {
        commitsInfo.textContent = formatCommitDate(data.pushedAt);
        (commitsEl as HTMLElement).style.display = 'flex';
      }

      const versionEl = card.querySelector('.pkg-version');
      if (versionEl && data.version) {
        versionEl.textContent = `v${data.version}`;
        (versionEl as HTMLElement).style.display = 'inline-block';
      }
    });
  }

  loadProjectData();
</script>
