)}

<script>
  const CACHE_KEY = 'oss-descriptions-cache';
  const CACHE_DURATION_MS = 60 * 60 * 1000; // 1 hour

  interface CacheData {
    [repo: string]: string;
  }

  function getCachedDescriptions(): CacheData | null {
    try {
      const cached = localStorage.getItem(CACHE_KEY);
      if (!cached) return null;

      const { data, timestamp } = JSON.parse(cached);
      const age = Date.now() - timestamp;

      if (age > CACHE_DURATION_MS) {
        localStorage.removeItem(CACHE_KEY);
        return null;
      }

      return data;
    } catch {
      return null;
    }
  }

  function setCachedDescriptions(data: CacheData): void {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify({
        data,
        timestamp: Date.now()
      }));
    } catch {
      // localStorage might be full or disabled
    }
  }

  async function loadDescriptions(): Promise<void> {
    const cards = document.querySelectorAll('.oss-project-card');
    const cachedData = getCachedDescriptions() || {};
    const reposToFetch: string[] = [];

    // Check which repos need fetching
    cards.forEach(card => {
      const repo = card.getAttribute('data-repo');
      if (repo && !cachedData[repo]) {
        reposToFetch.push(repo);
      }
    });

    // Fetch missing descriptions
    if (reposToFetch.length > 0) {
      await Promise.all(reposToFetch.map(async repo => {
        try {
          const response = await fetch(`https://api.github.com/repos/${repo}`, {
            headers: {
              'Accept': 'application/vnd.github+json',
            }
          });
          if (response.ok) {
            const data = await response.json();
            cachedData[repo] = data.description || 'No description available';
          }
        } catch (error) {
          console.error(`Failed to fetch description for ${repo}:`, error);
          cachedData[repo] = 'No description available';
        }
      }));

      setCachedDescriptions(cachedData);
    }

    // Update DOM
    cards.forEach(card => {
      const repo = card.getAttribute('data-repo');
      const descEl = card.querySelector('.github-description');
      if (repo && descEl && cachedData[repo]) {
        descEl.textContent = `"${cachedData[repo]}"`;
      }
    });
  }

  loadDescriptions();
</script>
