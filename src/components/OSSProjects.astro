                  <h4 style="color: var(--color-accent);" class="font-semibold">{project.name}</h4>
                  <div class="flex gap-2 flex-shrink-0">
                    <a
                      href={project.links.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      style="color: var(--color-text-muted);"
                      class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
