---
import { ossProjects, sectionIntro } from '../data/oss-projects';

const myPackages = ossProjects.filter(p => p.type === 'package');
const contributions = ossProjects.filter(p => p.type === 'contribution');
---

<section class="max-w-6xl mx-auto">
  <div class="card animate-slide-in-left" style="animation-delay: 450ms;">
    <!-- Ribbon overlay - top left -->
    <div class="absolute top-0 left-0 ribbon-top-left">
      <span style="background: var(--color-accent); color: white;" class="px-4 py-2 text-xs font-black uppercase tracking-wider shadow-lg">
        Open Source
      </span>
    </div>

    <div class="mt-8">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-green-400/30 to-emerald-400/30 flex items-center justify-center">
          <svg class="w-8 h-8" style="color: var(--color-accent);" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <div>
          <h2 style="color: var(--color-text-heading);" class="text-2xl font-bold">Open Source</h2>
          <p style="color: var(--color-text-secondary);" class="text-sm">Packages I maintain & projects I contribute to</p>
        </div>
      </div>

      <!-- Intro -->
      <p style="color: var(--color-text-secondary);" class="text-sm mb-8 leading-relaxed">
        {sectionIntro}
      </p>

      <!-- My Packages -->
      <div class="mb-8">
        <h3 style="color: var(--color-text-heading);" class="text-sm font-semibold uppercase tracking-wider mb-4 flex items-center gap-2">
          <span>📦</span> My Packages
        </h3>
        <div id="my-packages-content" class="space-y-4">
          {myPackages.map(project => (
            <div
              class="oss-project-card"
              data-repo={project.repo}
              data-my-description={project.myDescription || ''}
              style="background: var(--color-bg-secondary); border: 1px solid var(--color-border);"
            >
              <div class="p-4 rounded-lg">
                <div class="flex items-start justify-between gap-4 mb-2">
                  <h4 style="color: var(--color-accent);" class="font-semibold">{project.name}</h4>
                  <div class="flex gap-2 flex-shrink-0">
                    <a
                      href={project.links.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      style="color: var(--color-text-muted);"
                      class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
                    >
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                      </svg>
                      GitHub
                    </a>
                    {project.links.pypi && (
                      <a
                        href={project.links.pypi}
                        target="_blank"
                        rel="noopener noreferrer"
                        style="color: var(--color-text-muted);"
                        class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
                      >
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12.042 23.648c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637zm7.74-4.771c-.805-.503-1.227-1.064-1.227-1.637 0-.573.422-1.134 1.227-1.637.806.503 1.228 1.064 1.228 1.637 0 .573-.422 1.134-1.228 1.637zm-15.48 0c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637zm7.74-4.771c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637z"/>
                        </svg>
                        PyPI
                      </a>
                    )}
                    {project.links.rubygems && (
                      <a
                        href={project.links.rubygems}
                        target="_blank"
                        rel="noopener noreferrer"
                        style="color: var(--color-text-muted);"
                        class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
                      >
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.25l8.25 4.714v9.536L12 21.214 3.75 16.5V6.964L12 2.25z"/>
                        </svg>
                        RubyGems
                      </a>
                    )}
                  </div>
                </div>
                <p class="github-description text-sm italic mb-2" style="color: var(--color-text-muted);">
                  Loading...
                </p>
                {project.myDescription && (
                  <p class="text-sm leading-relaxed" style="color: var(--color-text);">
                    {project.myDescription}
                  </p>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Contributions -->
      {contributions.length > 0 && (
        <div>
          <h3 style="color: var(--color-text-heading);" class="text-sm font-semibold uppercase tracking-wider mb-4 flex items-center gap-2">
            <span>🤝</span> Contributions
          </h3>
          <div id="contributions-content" class="space-y-4">
            {contributions.map(project => (
              <div
                class="oss-project-card"
                data-repo={project.repo}
                data-my-description={project.myDescription || ''}
                style="background: var(--color-bg-secondary); border: 1px solid var(--color-border);"
              >
                <div class="p-4 rounded-lg">
                  <div class="flex items-start justify-between gap-4 mb-2">
                    <h4 style="color: var(--color-accent);" class="font-semibold">{project.name}</h4>
                    <div class="flex gap-2 flex-shrink-0">
                      <a
                        href={project.links.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        style="color: var(--color-text-muted);"
                        class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
                      >
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                        </svg>
                        GitHub
                      </a>
                      {project.links.pypi && (
                        <a
                          href={project.links.pypi}
                          target="_blank"
                          rel="noopener noreferrer"
                          style="color: var(--color-text-muted);"
                          class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1"
                        >
                          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12.042 23.648c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637zm7.74-4.771c-.805-.503-1.227-1.064-1.227-1.637 0-.573.422-1.134 1.227-1.637.806.503 1.228 1.064 1.228 1.637 0 .573-.422 1.134-1.228 1.637zm-15.48 0c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637zm7.74-4.771c-.806-.503-1.228-1.064-1.228-1.637 0-.573.422-1.134 1.228-1.637.805.503 1.227 1.064 1.227 1.637 0 .573-.422 1.134-1.227 1.637z"/>
                          </svg>
                          PyPI
                        </a>
                      )}
                    </div>
                  </div>
                  <p class="github-description text-sm italic mb-2" style="color: var(--color-text-muted);">
                    Loading...
                  </p>
                  {project.myDescription && (
                    <p class="text-sm leading-relaxed" style="color: var(--color-text);">
                      {project.myDescription}
                    </p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<script>
  const CACHE_KEY = 'oss-descriptions-cache';
  const CACHE_DURATION_MS = 60 * 60 * 1000; // 1 hour

  interface CacheData {
    [repo: string]: string;
  }

  function getCachedDescriptions(): CacheData | null {
    try {
      const cached = localStorage.getItem(CACHE_KEY);
      if (!cached) return null;

      const { data, timestamp } = JSON.parse(cached);
      const age = Date.now() - timestamp;

      if (age > CACHE_DURATION_MS) {
        localStorage.removeItem(CACHE_KEY);
        return null;
      }

      return data;
    } catch {
      return null;
    }
  }

  function setCachedDescriptions(data: CacheData): void {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify({
        data,
        timestamp: Date.now()
      }));
    } catch {
      // localStorage might be full or disabled
    }
  }

  async function loadDescriptions(): Promise<void> {
    const cards = document.querySelectorAll('.oss-project-card');
    const cachedData = getCachedDescriptions() || {};
    const reposToFetch: string[] = [];

    // Check which repos need fetching
    cards.forEach(card => {
      const repo = card.getAttribute('data-repo');
      if (repo && !cachedData[repo]) {
        reposToFetch.push(repo);
      }
    });

    // Fetch missing descriptions
    if (reposToFetch.length > 0) {
      await Promise.all(reposToFetch.map(async repo => {
        try {
          const response = await fetch(`https://api.github.com/repos/${repo}`, {
            headers: {
              'Accept': 'application/vnd.github+json',
            }
          });
          if (response.ok) {
            const data = await response.json();
            cachedData[repo] = data.description || 'No description available';
          }
        } catch (error) {
          console.error(`Failed to fetch description for ${repo}:`, error);
          cachedData[repo] = 'No description available';
        }
      }));

      setCachedDescriptions(cachedData);
    }

    // Update DOM
    cards.forEach(card => {
      const repo = card.getAttribute('data-repo');
      const descEl = card.querySelector('.github-description');
      if (repo && descEl && cachedData[repo]) {
        descEl.textContent = `"${cachedData[repo]}"`;
      }
    });
  }

  loadDescriptions();
</script>
