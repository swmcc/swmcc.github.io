                  {project.links.rubygems && (
                    <a href={project.links.rubygems} target="_blank" rel="noopener noreferrer" style="color: var(--color-text-muted);" class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.25l8.25 4.714v9.536L12 21.214 3.75 16.5V6.964L12 2.25z"/></svg>
                      RubyGems
                    </a>
                  )}
                </div>
              </div>
              <p class="github-description text-sm italic mb-2" style="color: var(--color-text-muted);">Loading...</p>
              {project.myDescription && (<p class="text-sm leading-relaxed" style="color: var(--color-text);">{project.myDescription}</p>)}
            </div>
          </div>
        ))}
      </div>
    </div>

    {contributions.length > 0 && (
      <div>
        <h3 style="color: var(--color-text-heading);" class="text-sm font-semibold uppercase tracking-wider mb-4 flex items-center gap-2">
          <span>🤝</span> Contributions
        </h3>
        <div id="contributions-content" class="space-y-4">
          {contributions.map(project => (
            <div
              class="oss-project-card"
              data-repo={project.repo}
              data-my-description={project.myDescription || ''}
