  <section class="max-w-6xl mx-auto">
    <div class="card animate-slide-in-left" style="animation-delay: 450ms;">
      {showRibbon && (
        <div class="absolute top-0 left-0 ribbon-top-left">
          <span style="background: var(--color-accent); color: white;" class="px-4 py-2 text-xs font-black uppercase tracking-wider shadow-lg">
            Open Source
