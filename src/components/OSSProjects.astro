---
import { ossProjects, sectionIntro } from '../data/oss-projects';

interface Props {
  showRibbon?: boolean;
  hideWrapper?: boolean;
}

const { showRibbon = true, hideWrapper = false } = Astro.props;
const myPackages = ossProjects.filter(p => p.type === 'package');
const contributions = ossProjects.filter(p => p.type === 'contribution');
---

{hideWrapper ? (
  <Fragment>
    <div class="flex items-center gap-3 mb-6">
      <div class="w-16 h-16 rounded-full bg-gradient-to-br from-green-400/30 to-emerald-400/30 flex items-center justify-center">
        <svg class="w-8 h-8" style="color: var(--color-accent);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
        </svg>
      </div>
      <div>
        <h2 style="color: var(--color-text-heading);" class="text-2xl font-bold">Open Source</h2>
        <p style="color: var(--color-text-secondary);" class="text-sm">Packages I maintain & projects I contribute to</p>
      </div>
    </div>

    <p style="color: var(--color-text-secondary);" class="text-sm mb-8 leading-relaxed">
      {sectionIntro}
    </p>

    <div class="mb-8">
      <h3 style="color: var(--color-text-heading);" class="text-sm font-semibold uppercase tracking-wider mb-4 flex items-center gap-2">
        <span>📦</span> My Packages
      </h3>
      <div id="my-packages-content" class="space-y-4">
        {myPackages.map(project => (
          <div
            class="oss-project-card"
            data-repo={project.repo}
            data-my-description={project.myDescription || ''}
            style="background: var(--color-bg-secondary); border: 1px solid var(--color-border);"
          >
            <div class="p-4 rounded-lg">
              <div class="flex items-start justify-between gap-4 mb-2">
                <h4 style="color: var(--color-accent);" class="font-semibold">{project.name}</h4>
                <div class="flex gap-2 flex-shrink-0">
                  <a href={project.links.github} target="_blank" rel="noopener noreferrer" style="color: var(--color-text-muted);" class="text-xs hover:opacity-70 transition-opacity flex items-center gap-1">
